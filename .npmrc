# Bangicode npm config
# When `npm install <pkg>` is run, write the exact installed version into
# package.json (no ^ or ~ ranges). The lockfile is still the source of truth
# for reproducible installs; this keeps package.json semver honest too.
save-exact=true

# Refuse to install if the host Node/npm don't satisfy the `engines` field
# in package.json. Prevents subtle version-skew bugs.
engine-strict=true
